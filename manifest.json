{
  "manifest_version": 2,
  "name": "AI Pulse",
  "version": "2.0.0",
  "description": "Your AI/ML feed — GitHub trending, Anthropic, Claude, OpenAI, Codex, and Hacker News in one new-tab dashboard.",
  "author": "Salil Gautam",
  "homepage_url": "https://github.com/salil-gtm/ai-pulse",
  "permissions": [
    "alarms",
    "storage",
    "notifications",
    "https://api.github.com/*",
    "https://www.anthropic.com/*",
    "https://claude.com/*",
    "https://openai.com/*",
    "https://developers.openai.com/*",
    "https://hacker-news.firebaseio.com/*",
    "https://raw.githubusercontent.com/*",
    "https://github.com/*"
  ],
  "browser_action": {
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    },
    "default_title": "AI Pulse"
  },
  "background": {
    "scripts": [
      "lib/db.js",
      "lib/keywords.js",
      "lib/summarize.js",
      "lib/fetchers/github.js",
      "lib/fetchers/anthropic.js",
      "lib/fetchers/openai.js",
      "lib/fetchers/hackernews.js",
      "background/background.js"
    ]
  },
  "chrome_url_overrides": {
    "newtab": "newtab/newtab.html"
  },
  "options_ui": {
    "page": "settings/settings.html",
    "open_in_tab": true
  },
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  }
}
